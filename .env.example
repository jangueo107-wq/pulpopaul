# ─── Local ───────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# Secreto JWT (mín. 32 caracteres). Generar: openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# Hash bcrypt de la contraseña principal (editable desde Configuración).
# Generar: node -e "require('bcryptjs').hash('TU_CLAVE',12).then(console.log)"
MASTER_PASSWORD_HASH="$2b$12$xRNVpGvp.qdnpik.EWsgmeJIsm9/emkjWncQg38qtuR8upsZ3gwSe"

# Hash bcrypt de la clave de recuperación fija (solo backend, no editable en UI).
RECOVERY_PASSWORD_HASH="$2b$12$9GHO4kL2HyunozBvrfgLVuIMadfTIB0MXYDceGt7flw0bu7omhdqO"

# Usuario inicial: PulpoPaul
# Ejecutar: npm run db:seed (datos demo) o npm run db:update-user (solo usuario)

# ─── Producción (Vercel + dominio propio) ─────────────────────────────
# 1. Variables en Vercel → Settings → Environment Variables:
#    AUTH_SECRET, MASTER_PASSWORD_HASH, RECOVERY_PASSWORD_HASH, DATABASE_URL
#
# 2. Base de datos: SQLite local no persiste en Vercel serverless.
#    Opciones recomendadas:
#    - Turso (libsql): https://turso.tech — DATABASE_URL="libsql://..."
#    - VPS / Railway con disco persistente y file:./prod.db
#
# 3. Tras el primer deploy, ejecutar seed/migración contra la BD de prod.
#
# 4. Dominio: Vercel → Project → Settings → Domains → agregar tu dominio.
#    El logo y assets en /public se sirven en /logo.png (sin /public en la URL).

# Opcional — URL pública del sitio (útil para cookies/metadata futuros)
# NEXT_PUBLIC_APP_URL="https://tudominio.com"
